#!/usr/bin/make -f

EXT_ID := jhejkohfkfaeidbbnhjkicadefnapedo

%:
	dh $@

override_dh_auto_build:
	dune build --profile release bin/server/main.exe bin/client/main.exe \
		extension/main.bc.js extension/popup.bc.js extension/config_page.bc.js \
		extension/options_page.bc.js extension/add_rule_page.bc.js
	mkdir -p _build/ext-staging/icons
	cp extension/manifest.json extension/popup.html extension/add_rule.html extension/config.html extension/options.html _build/ext-staging/
	cp _build/default/extension/main.bc.js _build/ext-staging/main.js
	cp _build/default/extension/popup.bc.js _build/ext-staging/popup.js
	cp _build/default/extension/config_page.bc.js _build/ext-staging/config.js
	cp _build/default/extension/options_page.bc.js _build/ext-staging/options.js
	cp _build/default/extension/add_rule_page.bc.js _build/ext-staging/add_rule.js
	cp extension/icons/* _build/ext-staging/icons/
	cd extension && npx crx3 ../_build/ext-staging \
		--crxPath ../_build/extension.crx --keyPath key.pem

override_dh_auto_test:

override_dh_auto_install:
	install -D -m 755 _build/default/bin/server/main.exe \
		debian/alloyd/usr/bin/alloyd
	install -D -m 755 _build/default/bin/client/main.exe \
		debian/alloy/usr/bin/alloy
	# Canonical native messaging manifest
	install -D -m 644 debian/alloy.json \
		debian/alloy/usr/share/alloy/alloy.json
	# Symlink for each browser
	mkdir -p debian/alloy/etc/chromium/native-messaging-hosts
	ln -sf /usr/share/alloy/alloy.json \
		debian/alloy/etc/chromium/native-messaging-hosts/alloy.json
	mkdir -p debian/alloy/etc/opt/chrome/native-messaging-hosts
	ln -sf /usr/share/alloy/alloy.json \
		debian/alloy/etc/opt/chrome/native-messaging-hosts/alloy.json
	mkdir -p debian/alloy/etc/opt/edge/native-messaging-hosts
	ln -sf /usr/share/alloy/alloy.json \
		debian/alloy/etc/opt/edge/native-messaging-hosts/alloy.json
	# Edge extension descriptor (external_update_url via HTTP)
	install -D -m 644 debian/$(EXT_ID).json \
		debian/alloy/usr/share/alloy/$(EXT_ID).json
	for variant in msedge msedge-beta msedge-dev msedge-canary; do \
		mkdir -p debian/alloy/opt/microsoft/$$variant/extensions; \
		ln -sf /usr/share/alloy/$(EXT_ID).json \
			debian/alloy/opt/microsoft/$$variant/extensions/$(EXT_ID).json; \
	done
	# Chromium/Chrome: install unpacked extension for "Load unpacked" or external_crx
	mkdir -p debian/alloy/usr/share/alloy/extension
	cp -r _build/ext-staging/* debian/alloy/usr/share/alloy/extension/
	install -D -m 644 _build/extension.crx \
		debian/alloy/usr/share/alloy/extension.crx
	install -D -m 644 debian/updates.xml \
		debian/alloy/usr/share/alloy/updates.xml
	install -D -m 644 debian/alloy.desktop \
		debian/alloy/usr/share/applications/alloy.desktop
	install -D -m 644 config.example.json \
		debian/alloyd/usr/share/doc/alloyd/config.example.json

override_dh_auto_clean:
	dune clean
	rm -rf _build/ext-staging _build/extension.crx

override_dh_dwz:
override_dh_strip:
override_dh_shlibdeps:
