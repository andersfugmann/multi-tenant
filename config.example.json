{
  "listen": ["127.0.0.1:7120", "[::1]:7120"],
  "allowed_networks": ["127.0.0.0/8", "::1/128"],
  "tenants": {
    "host-machine": {
      "label": "Host",
      "color": "#4285F4",
      "brand": "Google Chrome"
    },
    "work-container": {
      "browser_cmd": "machinectl shell work-container /usr/bin/chromium",
      "label": "Work",
      "color": "#EA4335"
    }
  },
  "rules": [
    {
      "pattern": "https://github[.]com/.*",
      "target": "work-container",
      "enabled": true
    },
    {
      "pattern": "https://mail[.]google[.]com/.*",
      "target": "host-machine",
      "enabled": true
    }
  ],
  "defaults": {
    "unmatched": "local",
    "cooldown_seconds": 2,
    "browser_launch_timeout": 10
  }
}
