{
  "manifest_version": 3,
  "name": "URL Router",
  "version": "1.0",
  "description": "Route URLs between multi-tenant browser profiles",
  "permissions": ["webNavigation", "contextMenus", "nativeMessaging", "tabs", "activeTab"],
  "background": {
    "service_worker": "main.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon48.png"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
