{
  "manifest_version": 3,
  "name": "Alloy",
  "version": "0.9.5",
  "description": "Route URLs between browser profiles",
  "permissions": [
    "webNavigation",
    "contextMenus",
    "nativeMessaging",
    "tabs",
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "main.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16_disconnected.png",
      "48": "icons/icon48_disconnected.png",
      "128": "icons/icon128_disconnected.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "key": ""
}
