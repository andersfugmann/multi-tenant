{
  "manifest_version": 3,
  "name": "URL Router",
  "description": "Route URLs to the correct tenant browser",
  "version": "0.1.0",
  "permissions": [
    "webNavigation",
    "nativeMessaging",
    "contextMenus",
    "activeTab"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "URL Router"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
